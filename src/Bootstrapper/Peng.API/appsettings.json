{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/peng-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName"]
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=peng_db;Username=peng_user;Password=peng_pass"
  },
  "Jwt": {
    "SecretKey": "CHANGE_THIS_TO_A_LONG_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "peng-api",
    "Audience": "peng-client",
    "ExpirationSeconds": 3600
  },
  "AllowedOrigins": ["http://localhost:5173"],
  "AllowedHosts": "*"
}
